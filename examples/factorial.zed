syntax { inherit ZedSyntax; }

// Demonstrates: functions, conditionals, recursion (via cycle), and
// the z (zero) term.

define factorial (n) {
  when n = 0 {
    1
  } otherwise {
    result ← 1
    cycle i ← 1 until i > n {
      result ← result * i
      i ← i + 1
    }
    result
  }
}

define main {
  outward "ZedCore Factorial Demo"
  outward "5! ="
  outward factorial -> 5
  outward "10! ="
  outward factorial -> 10
  outward z
}
